# .env.example — Discord gh-bot 設定
# このファイルをコピーして .env にリネームし、値を埋めてください
# Koyebでは環境変数をダッシュボードから直接設定します（.envは不要）
# ============================================================

# Discord Developer Portal (https://discord.com/developers/applications)
# でボットを作成し、トークンをここに貼り付けます
DISCORD_TOKEN=your_discord_bot_token_here

# GitHub Personal Access Token（Koyebデプロイ時は必須）
# 作成: https://github.com/settings/tokens
# 必要スコープ: repo, read:org, workflow
GH_TOKEN=your_github_personal_access_token_here

# /gh コマンドを実行できる Discord ロール名
# サーバーで同名のロールを作成してメンバーに付与してください
ALLOWED_ROLE_NAME=gh-bot

# ヘルスチェックサーバーのポート（Koyebは自動設定）
# PORT=8000

# /git コマンドの作業ディレクトリ（省略時はカレント）
# GIT_WORK_DIR=/app/repos
